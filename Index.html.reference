                    <div class="ml-10 flex items-center space-x-8">
                        <a href="#templates" class="text-sm font-medium transition-colors" style="color: var(--text-secondary);">Templates</a>
                        <a href="#features" class="text-sm font-medium transition-colors" style="color: var(--text-secondary);">Features</a>
                        <a href="#about" class="text-sm font-medium transition-colors" style="color: var(--text-secondary);">About</a>
                        <a href="https://leanotion-shop.fourthwall.com" target="_blank" class="px-4 py-2 rounded-full text-sm font-semibold transition-colors-theme" style="background: var(--text-primary); color: var(--bg-primary);">
